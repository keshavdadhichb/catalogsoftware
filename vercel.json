{
    "version": 2,
    "builds": [
        {
            "src": "bono-catalog-be/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "bono-catalog-fe/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "bono-catalog-be/main.py"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/bono-catalog-fe/assets/$1"
        },
        {
            "src": "/([^/]+\\.[^/]+)",
            "dest": "/bono-catalog-fe/$1"
        },
        {
            "src": "/(?!api/)(.*)",
            "dest": "/bono-catalog-fe/index.html"
        }
    ]
}
